{
  "alias": ["weave-synchub-app.vercel.app"],
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path":     "/api/cron/check-expiry",
      "schedule": "0 9 * * *"
    }
  ]
}
