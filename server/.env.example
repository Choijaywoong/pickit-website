# 절대 .env 파일을 git에 올리지 말 것 (API Key 노출 위험)

PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/pickit

# 채널별 API Key (서버 측 암호화 저장 원칙)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
# 셀러의 카페24 쇼핑몰 아이디 (예: mystore → mystore.cafe24.com)
CAFE24_MALL_ID=
# 카페24 앱 설정의 'Redirect URI' 항목에 동일하게 입력해야 함
CAFE24_REDIRECT_URI=http://localhost:4000/api/oauth/cafe24/callback

# 프론트 주소 (OAuth 완료 후 리다이렉트 목적지)
FRONTEND_URL=http://localhost:5173

MUSINSA_API_KEY=
ABLY_API_KEY=
ZIGZAG_API_KEY=

# LLM
ANTHROPIC_API_KEY=
