# 절대 .env 파일을 git에 올리지 말 것 (API Key 노출 위험)
# 이 파일(.env.example)은 git에 올려도 됩니다 — 실제 값이 없는 샘플입니다.

PORT=4000

# Supabase PostgreSQL 연결 문자열
# Supabase 대시보드 → Project Settings → Database → Connection string → URI 탭에서 복사
# 형식: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# 데모 모드: true로 설정하면 실제 API 없이 목 응답 반환 (POC 시연용)
# Anthropic API Key가 없으면 자동으로 데모 모드로 전환됨
DEMO_MODE=false

# ──────────────────────────────────────────────────
# [PICKIT 플랫폼 자격증명] — PICKIT 운영자(개발자)가 설정
# 셀러 Settings UI에는 절대 노출하지 않음
# ──────────────────────────────────────────────────

# Anthropic (AI 채팅 엔진)
ANTHROPIC_API_KEY=

# 카페24 — PICKIT 앱으로 카페24 개발자센터에 등록 후 발급
# https://developers.cafe24.com → 내 앱 → 앱 등록
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
# 카페24 앱 설정의 'Redirect URI'와 동일하게 입력
CAFE24_REDIRECT_URI=http://localhost:4000/api/oauth/cafe24/callback

# 프론트 주소 (OAuth 완료 후 리다이렉트 목적지)
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────────
# [셀러 자격증명] — 셀러가 Settings UI에서 직접 입력
# credentialStore에 저장됨, git에 올리지 않음
# ──────────────────────────────────────────────────

# 쿠팡 — 쿠팡 파트너스 > API 관리에서 발급
COUPANG_VENDOR_ID=
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# 네이버 스마트스토어 — NCP(네이버 클라우드) > Commerce API에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 카페24 — 셀러 본인의 쇼핑몰 아이디 (OAuth 후 액세스 토큰은 자동 저장)
CAFE24_MALL_ID=

# 무신사 — 파트너 개발자 문서에서 발급 (1년 만료, 갱신 알림 필요)
MUSINSA_API_KEY=

# 에이블리 — 셀러스(Sellers) 입점 타입만 지원
ABLY_API_KEY=

# 지그재그
ZIGZAG_API_KEY=
